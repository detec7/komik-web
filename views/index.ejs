<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Daftar Komik</title>
    <style>
        body { background-color: #0b1320; color: #e2e8f0; font-family: sans-serif; padding: 40px; margin: 0; }
        .container { max-width: 800px; margin: 0 auto; }
        h1 { border-bottom: 2px solid #1e293b; padding-bottom: 10px; }
        .chapter-list { list-style: none; padding: 0; }
        .chapter-item { background-color: #0f172a; margin-bottom: 10px; padding: 15px; border-radius: 5px; display: flex; justify-content: space-between; align-items: center; }
        .chapter-link { color: #38bdf8; text-decoration: none; font-weight: bold; padding: 8px 15px; background-color: #1e293b; border-radius: 5px;}
        .chapter-link:hover { background-color: #3b82f6; color: white; }
    </style>
</head>
<body>

    <div class="container">
        <h1>Update Terbaru</h1>
        
        <ul class="chapter-list">
            <!-- Melakukan perulangan untuk mencetak semua chapter dari database -->
            <% if (listChapter.length === 0) { %>
                <p style="color: #94a3b8;">Belum ada chapter yang diunggah.</p>
            <% } else { %>
                <% listChapter.forEach(function(chapter) { %>
                    <li class="chapter-item">
                        <span><strong><%= chapter.judulKomik %></strong> - Chapter <%= chapter.nomorChapter %></span>
                        <!-- Link dinamis menuju halaman baca khusus untuk chapter ini -->
                        <a href="/baca/<%= chapter._id %>" class="chapter-link">Baca</a>
                    </li>
                <% }); %>
            <% } %>
        </ul>
    </div>

</body>
</html>