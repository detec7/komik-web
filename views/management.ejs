<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Series Management</title>
    <style>
        body { font-family: sans-serif; margin: 0; background-color: #0b1320; color: #e2e8f0; display: flex; height: 100vh;}
        .sidebar { width: 250px; background-color: #0f172a; padding: 20px; display: flex; flex-direction: column; justify-content: space-between; border-right: 1px solid #1e293b;}
        .menu-item { padding: 15px; margin-bottom: 5px; border-radius: 5px; color: #94a3b8; text-decoration: none; display: block;}
        .menu-item:hover, .menu-item.active { background-color: #1e293b; color: white; }
        .content { flex-grow: 1; padding: 40px; overflow-y: auto;}
        
        /* Tabel Minimalis */
        table { width: 100%; border-collapse: collapse; margin-top: 20px; background-color: #0f172a; border-radius: 8px; overflow: hidden;}
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #1e293b; }
        th { background-color: #1e293b; color: white; }
        
        /* Tombol Aksi */
        .btn-edit { background-color: #22c55e; color: white; padding: 8px 15px; border-radius: 5px; text-decoration: none; font-weight: bold; font-size: 14px; margin-right: 10px;}
        .btn-delete { background-color: #ef4444; color: white; padding: 8px 15px; border-radius: 5px; border: none; cursor: pointer; font-weight: bold; font-size: 14px;}
    </style>
</head>
<body>

    <div class="sidebar">
        <div>
            <a href="/dashboard" class="menu-item">Series Upload</a>
            <a href="/management" class="menu-item active">Series Management</a>
            <a href="/" class="menu-item">Lihat Website</a>
        </div>

        <!-- Bagian Bawah Sidebar (Tombol Logout) -->
        <div style="padding-bottom: 20px;">
            <a href="/logout" class="menu-item" style="color: #ef4444; border: 1px solid #ef4444; text-align: center; font-weight: bold;">Logout</a>
        </div>
    </div>

    <div class="content">
        <h2>Series Management</h2>
        <p style="color: #94a3b8;">Daftar semua chapter yang telah diunggah.</p>
        
        <table>
            <tr>
                <th>Judul Komik</th>
                <th>Chapter</th>
                <th>Aksi</th>
            </tr>
            <% listChapter.forEach(function(ch) { %>
            <tr>
                <td style="font-weight: bold; color: #38bdf8;"><%= ch.judulKomik %></td>
                <td>Chapter <%= ch.nomorChapter %></td>
                <td>
                    <!-- Tombol Edit -->
                    <a href="/edit-chapter/<%= ch._id %>" class="btn-edit">Edit</a>
                    
                    <!-- Tombol Delete -->
                    <form action="/delete-chapter/<%= ch._id %>" method="POST" style="display:inline;" onsubmit="return confirm('Yakin ingin menghapus chapter ini?');">
                        <button type="submit" class="btn-delete">Delete</button>
                    </form>
                </td>
            </tr>
            <% }); %>
        </table>
    </div>

</body>
</html>