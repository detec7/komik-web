<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <!-- MISI 1: Mengubah Judul Tab -->
    <title><%= chapter.judulKomik %> Chapter <%= chapter.nomorChapter %></title>
    <style>
        body { background-color: #0b1320; color: white; font-family: sans-serif; text-align: center; margin: 0; padding: 20px; }
        .reader-container { max-width: 800px; margin: 0 auto; }
        
        /* MISI 3: Styling Tombol Home di Kiri dan Judul di Tengah */
        .header-nav { display: flex; align-items: center; justify-content: center; position: relative; margin-bottom: 30px; margin-top: 10px; }
        .btn-home { position: absolute; left: 0; background-color: #3b82f6; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-weight: bold; transition: 0.2s; }
        .btn-home:hover { background-color: #2563eb; }
        .chapter-title { margin: 0; font-size: 22px; color: #e2e8f0; }
        
        /* Pengaturan Canvas untuk gambar */
        canvas { display: block; margin: 0 auto; max-width: 100%; margin-bottom: -4px; } /* margin-bottom -4px untuk menghilangkan celah antar gambar */
    </style>
</head>
<body oncontextmenu="return false;"> <!-- Anti Klik Kanan -->

    <div class="reader-container">
        
        <!-- Header dengan Tombol Home -->
        <div class="header-nav">
            <a href="/" class="btn-home">Home</a>
            <h2 class="chapter-title"><%= chapter.judulKomik %> Chapter <%= chapter.nomorChapter %> Bahasa Indonesia</h2>
        </div>

        <!-- Wadah untuk memuat Canvas Gambar -->
        <div id="reader-area"></div>
    </div>

    <script>
        // MISI 4: SISTEM ANTI FATKUN (Canvas Rendering + URL Blob)
        const imageUrls = <%- JSON.stringify(chapter.gambar || []) %>;
        const container = document.getElementById('reader-area');

        imageUrls.forEach(url => {
            // Membuat elemen Canvas (Bukan <img>, sehingga Fatkun tidak bisa membacanya)
            const canvas = document.createElement('canvas');
            container.appendChild(canvas);

            const ctx = canvas.getContext('2d');
            const img = new Image();
            
            // Izin keamanan lintas server (Wajib untuk Cloudinary)
            img.crossOrigin = "Anonymous"; 
            
            // Logika ketika gambar selesai dimuat
            img.onload = function() {
                canvas.width = img.width;
                canvas.height = img.height;
                ctx.drawImage(img, 0, 0); // Melukis gambar ke dalam canvas
            };
            
            // Mengubah URL Cloudinary menjadi URL Blob (Teks Acak Lokal) agar URL asli tidak muncul di DOM
            fetch(url)
                .then(response => response.blob())
                .then(blob => {
                    const blobUrl = URL.createObjectURL(blob);
                    img.src = blobUrl; // Memasukkan URL samaran ke mesin pelukis
                })
                .catch(err => {
                    // Jika jaringan lambat, gunakan URL asli sebagai cadangan
                    img.src = url; 
                });
        });

        // Anti Inspect Element (Mencegah F12, Ctrl+Shift+I, Ctrl+U)
        document.onkeydown = function(e) {
            if (e.keyCode == 123 || 
               (e.ctrlKey && e.shiftKey && (e.keyCode == 'I'.charCodeAt(0) || e.keyCode == 'C'.charCodeAt(0) || e.keyCode == 'J'.charCodeAt(0))) || 
               (e.ctrlKey && e.keyCode == 'U'.charCodeAt(0))) {
                return false;
            }
        };
    </script>
</body>
</html>