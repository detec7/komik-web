<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <style>
        body { font-family: sans-serif; margin: 0; background-color: #0b1320; color: #a0aec0; display: flex; height: 100vh;}
        /* Desain Sidebar Kiri */
        .sidebar { width: 250px; background-color: #0f172a; padding: 20px; display: flex; flex-direction: column; justify-content: space-between; border-right: 1px solid #1e293b;}
        .menu-item { padding: 15px; margin-bottom: 5px; cursor: pointer; border-radius: 5px; }
        .menu-item:hover { background-color: #1e293b; color: white; }
        .logout-btn { background-color: #0f172a; color: white; border: 1px solid #1e293b; padding: 15px; border-radius: 5px; cursor: pointer; text-align: center;}
        /* Desain Konten Kanan */
        .content { flex-grow: 1; padding: 40px; }
        h2 { color: white; }
    </style>
</head>
<body>

    <div class="sidebar" style="display: flex; flex-direction: column; justify-content: space-between; height: 100vh;">
        <div>
            <a href="/dashboard" class="menu-item" style="color: white; text-decoration: none; padding: 15px; display: block; margin-bottom: 5px; background-color: #1e293b; border-radius: 5px;">Series Upload</a>
            <a href="/management" class="menu-item" style="color: #94a3b8; text-decoration: none; padding: 15px; display: block; margin-bottom: 5px;">Series Management</a>
            <a href="/" class="menu-item" style="color: #94a3b8; text-decoration: none; padding: 15px; display: block; margin-bottom: 5px;">Lihat Website</a>
        </div>
        
        <!-- Bagian Bawah Sidebar (Tombol Logout) -->
        <div style="padding-bottom: 20px;">
            <a href="/logout" class="menu-item" style="color: #ef4444; text-decoration: none; padding: 15px; display: block; border: 1px solid #ef4444; border-radius: 5px; font-weight: bold; text-align: center;">Logout</a>
        </div>
    </div>

    <div class="content">
        <h2>Series Upload</h2>
        <p>Pilih beberapa gambar sekaligus untuk diunggah.</p>
        
        <!-- Form upload yang diperbarui -->
        <form action="/upload-chapter" method="POST" enctype="multipart/form-data" style="background-color: #1e293b; padding: 20px; border-radius: 8px; max-width: 500px; display: flex; flex-direction: column; gap: 15px;">
            
            <label style="color: white;">Judul Komik (Project):</label>
            <input type="text" name="judulKomik" required style="padding: 10px; border-radius: 5px; border: none;">

            <label style="color: white;">Nomor Chapter:</label>
            <input type="number" name="nomorChapter" required style="padding: 10px; border-radius: 5px; border: none;">

            <!-- BARU: Input untuk Cover Thumbnail -->
            <label style="color: white;">Cover Thumbnail (Ukuran ideal 720x1028):</label>
            <input type="file" name="cover" accept="image/*" style="color: white; border: 1px solid #475569; padding: 10px; border-radius: 5px;">

            <label style="color: white;">Pilih Folder Gambar Chapter:</label>
            <input type="file" name="gambarKomik" webkitdirectory directory multiple accept="image/*" style="color: white; border: 1px solid #475569; padding: 10px; border-radius: 5px;"> 
            
            <button type="submit" style="background-color: #3b82f6; color: white; padding: 12px; border: none; border-radius: 5px; cursor: pointer; font-weight: bold; margin-top: 10px;">Upload Project</button>
        </form>
    </div>

</body>
</html>